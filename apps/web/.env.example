SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_ORIGIN="http://localhost:4000"
APP_ORIGIN="http://localhost:4000"
PUBLIC_SITE_URL="http://localhost:4000"
VITE_PUBLIC_SITE_URL="http://localhost:4000"
AUTH_CODE_SECRET="generate-a-long-random-server-only-secret"

# Paystack
# Use keys from your Paystack dashboard. Never expose the secret key in client code.
PAYSTACK_MODE="live"
PAYSTACK_SECRET_KEY="sk_live_YOUR_PAYSTACK_SECRET_KEY"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_live_YOUR_PAYSTACK_PUBLIC_KEY"
PAYSTACK_CURRENCY="NGN"
# Optional. Defaults to APP_ORIGIN/PUBLIC_SITE_URL + /api/billing/paystack/callback
PAYSTACK_CALLBACK_URL=""

# Optional: point this at a Cloudflare/Supabase custom domain for public Storage assets.
# Example: https://cdn.yourdomain.com
STORAGE_CDN_ORIGIN=""

EMAIL_FROM="JOSTAP <no-reply@jostap.com>"
POSTMARK_SERVER_TOKEN=""
POSTMARK_MESSAGE_STREAM="outbound"
RESEND_API_KEY=""
